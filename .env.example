# Скопируй в .env и заполни реальными значениями. .env не коммитится.

# --- PostgreSQL (docker-compose) ---
POSTGRES_DB=poems
POSTGRES_USER=poems
POSTGRES_PASSWORD=поменяй-меня

# --- Админы приложения (обязательно), формат user:pass,user2:pass2 ---
APP_ADMINS=admin:поменяй-меня

# --- Telegram-уведомления (опционально) ---
#TELEGRAM_BOT_TOKEN=
#TELEGRAM_CHAT_ID=

# --- Прочее ---
#APP_AUTHOR_NAME=Алексей Боков
#THYMELEAF_CACHE=true
#RATE_LIMIT_MAX=5
#RATE_LIMIT_WINDOW_MINUTES=10
