<?xml version="1.0" encoding="UTF-8"?>
<!--
  Самодостаточная конфигурация логирования (не зависит от внутренних ресурсов Boot).
  - CONSOLE: всегда.
  - FILE: во всех профилях, кроме test — пишет в ${LOG_PATH}/poemorder.log
          с ротацией по дате/размеру (14 дней, до 200MB суммарно, сжатие .gz).
  Путь логов: переменная окружения LOG_PATH (по умолчанию ./logs). Папка logs/ в .gitignore.
-->
<configuration>

    <property name="LOG_PATH" value="${LOG_PATH:-logs}"/>
    <property name="PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Файл — везде, кроме тестов -->
    <springProfile name="!test">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/poemorder.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/poemorder-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>14</maxHistory>
                <totalSizeCap>200MB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${PATTERN}</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- В тестах только консоль, без файлов на диске -->
    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- Доменные события приложения видно подробнее -->
    <logger name="com.poemorder" level="DEBUG"/>

</configuration>
